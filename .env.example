# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- Database (Project Settings → Database → Connection string) ---
# Pooled connection (port 6543, pgbouncer) — used by the app at runtime.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used by `prisma db push` / migrations.
DIRECT_URL="postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# --- Stripe (test mode, Developers → API keys) ---
STRIPE_SECRET_KEY=sk_test_...
# From `stripe listen` locally, or the webhook endpoint settings in prod.
STRIPE_WEBHOOK_SECRET=whsec_...
# Prod only: separate Connect webhook endpoint (account.updated). Locally
# `stripe listen` signs everything with the secret above, so leave empty.
STRIPE_CONNECT_WEBHOOK_SECRET=
# Price ids of the two recurring prices you create in the Stripe dashboard.
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_UNLIMITED=price_...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Demo accounts (create these users in Supabase Auth manually) ---
DEMO_EMAIL=demo@quotly.app
DEMO_PASSWORD=change-me
# Seller demo: complete Stripe Express onboarding once with test data.
DEMO_SELLER_EMAIL=seller@quotly.app
DEMO_SELLER_PASSWORD=change-me

# --- Vercel cron auth (any random string; Vercel sends it as a Bearer token) ---
CRON_SECRET=change-me-too
